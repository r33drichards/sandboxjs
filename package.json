{
  "name": "@gitwit/sandbox",
  "version": "1.0.3",
  "description": "A unified interface for Linux-based cloud sandbox providers.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:integration": "vitest run tests/incus-integration.test.js --config vitest.config.ts --reporter=verbose --test-timeout=180000",
    "generate-client": "openapi-generator-cli generate -i incus-api.yaml -g typescript-axios -o src/generated/incus-client --skip-validate-spec --additional-properties=npmName=incus-client,supportsES6=true,enumPropertyNaming=original,modelPropertyNaming=original",
    "generate-client-from-url": "openapi-generator-cli generate -i $SPEC_URL -g typescript-axios -o src/generated/incus-client --skip-validate-spec --additional-properties=npmName=incus-client,supportsES6=true,enumPropertyNaming=original,modelPropertyNaming=original"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/ssh2": "^1.15.5",
    "@openapitools/openapi-generator-cli": "^2.14.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@codesandbox/sdk": "^2.1.0",
    "@daytonaio/sdk": "^0.27.1",
    "@e2b/cli": "^2.1.0",
    "@e2b/code-interpreter": "^1.2.0-beta.4",
    "axios": "^1.7.9",
    "docker-file-parser": "^1.0.7",
    "modal": "^0.3.15",
    "ssh2": "^1.17.0"
  }
}
